{
  "name": "@tcg/lorcana-types",
  "version": "0.1.0",
  "private": true,
  "description": "Lorcana-specific type definitions for abilities, effects, and cards",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./abilities": {
      "types": "./src/abilities/index.ts",
      "default": "./src/abilities/index.ts"
    },
    "./cards": {
      "types": "./src/cards/index.ts",
      "default": "./src/cards/index.ts"
    },
    "./targeting": {
      "types": "./src/targeting/index.ts",
      "default": "./src/targeting/index.ts"
    },
    "./expressions": {
      "types": "./src/expressions/index.ts",
      "default": "./src/expressions/index.ts"
    },
    "./name-generator": {
      "types": "./src/name-generator/generator.ts",
      "default": "./src/name-generator/generator.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && mkdir -p dist",
    "typecheck": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "format": "bun x oxfmt --write ./src",
    "lint": "vp lint ./src",
    "test": "bun test src",
    "check": "bun run format && bun run lint && bun run check-types"
  },
  "dependencies": {
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.14",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "typescript": "5.8.3"
  },
  "nx": {
    "tags": [
      "types"
    ]
  }
}
