{
  "$schema": "https://opencode.ai/config.json",
  "model": "alibaba/qwen3-coder-plus",
  "instructions": ["AGENTS.md"],
  "formatter": {
    "prettier": {
      "disabled": true
    },
    "biome": {
      "disabled": true
    }
  },
  "permission": {
    "*": {
      "*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "default_agent": "lead",
  "mcp": {
    "nx-mcp": {
      "type": "local",
      "command": ["npx", "nx", "mcp"],
      "enabled": true
    }
  }
}
