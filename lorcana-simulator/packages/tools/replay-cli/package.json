{
  "name": "@tcg/replay-cli",
  "version": "0.1.0",
  "private": true,
  "description": "CLI to download a Lorcana replay from production and print the per-turn trace for LLM debugging.",
  "bin": {
    "tcg-replay": "./src/cli.ts"
  },
  "type": "module",
  "scripts": {
    "check-types": "tsc --noEmit",
    "start": "bun ./src/cli.ts",
    "test": "bun test __tests__"
  },
  "dependencies": {
    "@tcg/lorcana-cards": "workspace:*",
    "@tcg/lorcana-types": "workspace:*",
    "mutative": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.4",
    "typescript": "5.9.3"
  }
}
