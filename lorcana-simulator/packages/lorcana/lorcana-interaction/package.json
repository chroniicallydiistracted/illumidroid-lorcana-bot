{
  "name": "@tcg/lorcana-interaction",
  "version": "0.1.0",
  "private": true,
  "description": "Renderer-agnostic player interaction view-model derived from the Lorcana engine's projected board",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    }
  },
  "scripts": {
    "typecheck": "bun run check-types",
    "check-types": "tsc --noEmit",
    "format": "bun x oxfmt --write './src/**/*.ts'",
    "lint": "vp lint ./src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "check": "bun run format && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@tcg/lorcana-engine": "workspace:*",
    "@tcg/lorcana-types": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "1.3.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "nx": {
    "tags": [
      "game-engine"
    ]
  }
}
