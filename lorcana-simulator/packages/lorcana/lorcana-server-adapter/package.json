{
  "name": "@tcg/lorcana-server-adapter",
  "version": "0.1.0",
  "private": true,
  "description": "Server-side GameAdapter implementation for Disney Lorcana — wires the Lorcana engine, cards data, and format validators into the @tcg/shared/game-adapter contract.",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "format": "bun x oxfmt --write ./src",
    "lint": "vp lint ./src",
    "check-types": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests"
  },
  "dependencies": {
    "@tcg/lorcana-cards": "workspace:*",
    "@tcg/lorcana-engine": "workspace:*",
    "@tcg/lorcana-types": "workspace:*",
    "@tcg/shared": "workspace:*"
  },
  "devDependencies": {
    "@tcg/typescript-config": "workspace:*",
    "@types/node": "^22.13.4"
  },
  "nx": {
    "tags": [
      "lorcana"
    ]
  }
}
