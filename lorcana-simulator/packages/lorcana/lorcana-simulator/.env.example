# Shared-domain production topology for Better Auth.
# PUBLIC_API_URL should point to the same origin used as AUTH_BASE_URL in apps/api.
PUBLIC_API_URL="https://api.example.com"
# Optional server-only override for SvelteKit load/actions running inside the simulator service.
# Use this for private infrastructure DNS.
# On Railway, include both the private DNS hostname and the target service port,
# for example: http://api.railway.internal:8080
PRIVATE_API_URL="http://api.internal:3000"
PUBLIC_GAME_SERVER_URL="https://game.example.com"
PUBLIC_GATEWAY_WS_URL="wss://game.example.com/v1/gateway/ws"
# Google Analytics 4 measurement ID. Leave empty to disable analytics entirely.
PUBLIC_GA4_MEASUREMENT_ID=""
