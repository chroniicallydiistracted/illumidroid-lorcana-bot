{
  "name": "@tcg/lorcana-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Disney Lorcana TCG engine implementation with an internal runtime core",
  "files": [
    "src/"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "imports": {
    "#core": "./src/core/index.ts",
    "#core/testing": "./src/core/testing/index.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./automation": {
      "types": "./src/automation/index.ts",
      "default": "./src/automation/index.ts"
    },
    "./i18n": {
      "types": "./src/i18n/index.ts",
      "default": "./src/i18n/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "default": "./src/testing/index.ts"
    },
    "./testing/matchers": {
      "types": "./src/testing/matchers.d.ts",
      "default": "./src/testing/matchers.d.ts"
    },
    "./support-probe": {
      "types": "./src/support-probe/index.ts",
      "default": "./src/support-probe/index.ts"
    }
  },
  "scripts": {
    "build": "bun run i18n:compile && tsc --noEmit && mkdir -p dist",
    "typecheck": "bun run check-types",
    "check-types": "tsc --noEmit",
    "i18n:verify": "bun run i18n:compile && bun run i18n:check",
    "i18n:compile": "pnpm dlx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/i18n/paraglide",
    "events:check": "bun run ./src/i18n/check-custom-event-usage.ts",
    "i18n:check": "bun run ./src/i18n/check-log-translations.ts && bun run ./src/i18n/check-custom-event-usage.ts",
    "audit:action-effect-coverage": "bun run ./scripts/audit-action-effect-resolver-coverage.ts",
    "format": "bun x oxfmt --write './src/**/*.ts'",
    "lint": "vp lint ./src",
    "test": "AGENT=1 bun test --silent --reporter=junit --reporter-outfile=./bun.xml",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "check": "bun run format && bun run lint && bun run check-types && bun run test"
  },
  "dependencies": {
    "@logtape/logtape": "^2.0.4",
    "@tcg/lorcana-types": "workspace:*",
    "mutative": "^1.1.0",
    "nanoid": "^5.0.0",
    "seedrandom": "^3.0.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.10.0",
    "@types/bun": "1.3.4",
    "@types/seedrandom": "^3.0.8",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "typescript": "5.9.3"
  },
  "nx": {
    "tags": [
      "game-engine"
    ]
  }
}
